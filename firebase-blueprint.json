{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "favorites": { "type": "array", "items": { "type": "string" } },
        "tasbihCount": { "type": "integer" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User specific data"
    }
  }
}
